# ============================================================
# Dockerfile.test — Lightweight build validation only
# Uses Alpine instead of PyTorch to test COPY/structure fast
# Run from project root:
#   docker build -f docker/Dockerfile.test -t runpood-test . && docker run --rm runpood-test
# ============================================================
FROM python:3.10-slim

WORKDIR /workspace

# ── Validate COPY instructions (same as real Dockerfile) ─────
COPY requirements.txt /tmp/requirements.txt
COPY app/          /workspace/app/
COPY scripts/      /workspace/scripts/
COPY rclone.conf   /workspace/rclone.conf

# ── Validate Python imports are syntactically correct ─────────
RUN python -m py_compile app/config.py && \
    python -m py_compile app/main.py && \
    python -m py_compile app/server.py && \
    python -m py_compile app/extractor.py && \
    python -m py_compile app/api_client.py && \
    python -m py_compile app/sync_google_drive.py && \
    python -m py_compile app/io_utils.py && \
    echo "✅ Python syntax OK"

# ── Validate shell scripts have no bash syntax errors ─────────
RUN bash -n /workspace/scripts/start_server.sh && \
    bash -n /workspace/scripts/run_extract.sh && \
    bash -n /workspace/scripts/download_models.sh && \
    bash -n /workspace/scripts/sync_from_gdrive.sh && \
    bash -n /workspace/scripts/sync_to_gdrive.sh && \
    echo "✅ Shell syntax OK"

# ── Validate rclone.conf has expected remote ─────────────────
RUN grep -q '\[gdrive\]' /workspace/rclone.conf && \
    grep -q 'refresh_token' /workspace/rclone.conf && \
    echo "✅ rclone.conf OK — remote [gdrive] found with refresh_token"

# ── Validate requirements.txt is parseable ───────────────────
RUN pip install --dry-run -r /tmp/requirements.txt 2>&1 | tail -5 && \
    echo "✅ requirements.txt parsed OK"

# ── Final report ──────────────────────────────────────────────
CMD ["bash", "-c", "echo '' && echo '============================================' && echo '  ✅ ALL VALIDATION CHECKS PASSED' && echo '  Image is ready for production build' && echo '============================================' && echo '' && echo 'Files in /workspace:' && find /workspace -type f | sort"]
